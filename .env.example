# Required for Lucia sessions, login, and signup (copy to .env.local).
# Without it you can open /login, but any DB-backed action will fail.
# PostgreSQL: Supabase, Neon, Docker local, etc.
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Optional: password for npm run db:seed (required in production; dev falls back to admin123 if unset).
# SEED_ADMIN_PASSWORD=your-secure-password-here
